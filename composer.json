{
    "name": "oscar-team/spryngsms",
    "description": "Spryng SMS Notification Channel for Laravel",
    "homepage": "https://github.com/oscar-team/spryngsms",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Adnan Shoukat",
            "email": "adnansunny821@gmail.com",
            "role": "Full Stack Developer",
            "homepage": "https://github.com/dani821"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/notifications": "~6.0 || ~7.0 || ~8.0 || ~9.0 || ~10.0 || ~11.0 || ~12.0 || ~13.0",
        "illuminate/support": "~6.0 || ~7.0 || ~8.0 || ~9.0 || ~10.0 || ~11.0 || ~12.0 || ~13.0",
        "spryng/rest-api-php": "^1.1"
    },
    "autoload": {
        "psr-4": {
            "Oscar\\Spryngsms\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Oscar\\Spryngsms\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Oscar\\Spryngsms\\SpryngsmsServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "require-dev": {
        "laravel/pint": "^1.0",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "scripts": {
        "test": "pest",
        "format": "pint"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    }
}